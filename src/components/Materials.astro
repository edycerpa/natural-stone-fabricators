---
const materials = [
  { name: "Granite", origin: "Natural igneous rock", properties: "Heat, scratch and stain resistant", best_for: "Kitchens, outdoor BBQs" },
  { name: "Marble", origin: "Natural metamorphic", properties: "Cool surface, timeless veining", best_for: "Bathrooms, fireplaces, accents" },
  { name: "Quartz", origin: "Engineered stone", properties: "Non-porous, consistent patterns", best_for: "Modern kitchens, commercial" },
  { name: "Porcelain", origin: "Sintered slab", properties: "UV-stable, ultra-thin options", best_for: "Outdoor, facades, large surfaces" },
];
---

<section class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <div class="lg:col-span-5 lg:sticky lg:top-28" data-anim="fade-right">
        <p class="eyebrow text-primary mb-3">Materials</p>
        <h2 class="text-ink text-3xl sm:text-4xl">The right stone, every time.</h2>
        <p class="mt-5 text-lg text-shade-dark leading-relaxed font-sans">
          Each project starts with choosing the right material. We fabricate in granite, marble, quartz and porcelain — and we help you pick based on use, exposure, and the look you want.
        </p>
      </div>

      <div class="lg:col-span-7 space-y-4">
        {materials.map(({ name, origin, properties, best_for }, i) => (
          <article
            class="p-6 sm:p-8 bg-primary-ultra-light/60 border-l-4 border-primary hover:bg-white hover:shadow-md transition-all font-sans"
            data-anim="fade-up"
            data-anim-delay={(i + 1) * 100}
          >
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <h3 class="text-2xl font-bold text-ink font-sans">{name}</h3>
              <p class="eyebrow text-primary">{origin}</p>
            </div>
            <dl class="mt-4 grid sm:grid-cols-2 gap-4">
              <div>
                <dt class="eyebrow text-primary">Properties</dt>
                <dd class="mt-1 text-sm text-shade-dark">{properties}</dd>
              </div>
              <div>
                <dt class="eyebrow text-primary">Best for</dt>
                <dd class="mt-1 text-sm text-shade-dark">{best_for}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>

    </div>
  </div>
</section>