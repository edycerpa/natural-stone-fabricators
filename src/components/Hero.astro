---
import { Image } from "astro:assets";
import heroImg from "../assets/image-31.jpg";
---

<section class="relative min-h-screen lg:min-h-[calc(100vh-5rem)] flex items-center pt-20 overflow-hidden">
  <!-- Desktop Split Background -->
  <div class="absolute inset-0 z-0 hidden lg:flex">
    <div class="w-[55%] bg-background"></div>
    <div class="w-[45%] relative">
      <Image
        src={heroImg}
        alt="Natural Stone Fabricators — premium stone craftsmanship in Orange County"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Subtle gradient to blend the edge -->
      <div class="absolute inset-0 bg-linear-to-r from-background to-transparent w-32"></div>
    </div>
  </div>

  <!-- Mobile Background -->
  <div class="absolute inset-0 z-0 lg:hidden">
    <Image
      src={heroImg}
      alt="Premium stone craftsmanship"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-background/95 backdrop-blur-md"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10 grid lg:grid-cols-12 gap-8 items-center py-20 lg:py-0">
    <div class="lg:col-span-7 pr-0 lg:pr-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-ultra-light border border-primary/20 mb-8" data-anim="fade-up" data-anim-delay="100">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-primary">20+ Years in Orange County</span>
      </div>
      
      <h1 class="text-6xl sm:text-7xl lg:text-[7rem] font-serif text-ink leading-[0.85]" data-anim="fade-up" data-anim-delay="200">
        Stone that <br/> lasts <span class="text-primary italic pr-2">generations.</span>
      </h1>
      
      <p class="mt-8 text-lg sm:text-xl text-shade-dark max-w-xl leading-relaxed font-sans" data-anim="fade-up" data-anim-delay="300">
        Fabrication and installation of premium granite, marble, quartz and porcelain. 
        Crafting breathtaking kitchens, bathrooms, and outdoor spaces across Southern California.
      </p>
      
      <div class="mt-10 flex flex-col sm:flex-row gap-4" data-anim="fade-up" data-anim-delay="400">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold uppercase tracking-wider bg-ink text-white hover:bg-primary transition-colors rounded-md shadow-xl shadow-ink/20">
          Request Free Estimate
        </a>
        <a href="/gallery" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold uppercase tracking-wider bg-white border border-shade-light/30 text-ink hover:border-primary hover:text-primary transition-all rounded-md shadow-sm">
          View Our Work
        </a>
      </div>
    </div>
  </div>
</section>