---
import { Image } from "astro:assets";
import heroImg from "../assets/isla-cocina-cascada-marmol-cebra.jpg";
import BackgroundGrid from "./BackgroundGrid.astro";
---

<BackgroundGrid class="min-h-screen pt-24">
  
  <!-- Full Screen Background Image & Left-to-Right Dark Gradient -->
  <div slot="background" class="absolute inset-0 z-0 overflow-hidden" id="hero-img-container">
    <Image
      src={heroImg}
      alt="Premium stone craftsmanship"
      class="w-full h-full object-cover origin-center opacity-100"
      id="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Left to right dark gradient for text readability -->
    <div class="absolute inset-0 z-10 bg-linear-to-r from-ink/80 via-ink/70 to-transparent"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex-1 flex flex-col lg:flex-row items-center relative pb-12">
    
    <!-- Left Text Content (Kept in its exact layout position) -->
    <div class="w-full lg:w-2/3 relative pt-10 lg:pt-0">
      <div class="hero-reveal overflow-hidden mb-6">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-accent">20+ Years in Orange County</p>
      </div>
      
      <h1 class="text-6xl sm:text-7xl lg:text-9xl font-serif text-white leading-[0.8] tracking-tight" style="text-shadow: 2px 2px 0px var(--color-ink);">
        <div class="overflow-hidden"><span class="hero-title-line block">Stone that</span></div>
        <div class="overflow-hidden"><span class="hero-title-line block">lasts <span class="italic text-accent pr-4">generations.</span></span></div>
      </h1>
      
      <div class="hero-reveal mt-10">
        <p class="text-xl sm:text-2xl text-shade-light leading-relaxed font-sans max-w-2xl">
          Fabrication and installation of premium granite, marble, quartz and porcelain. 
          Crafting breathtaking spaces across <span class="text-accent">Southern California</span>.
        </p>
      </div>
      
      <div class="hero-reveal mt-12 flex flex-col sm:flex-row gap-6 items-start">
        <a href="/contact" class="inline-flex items-center justify-center px-10 py-5 text-xs font-bold uppercase tracking-[0.2em] bg-white text-ink hover:bg-secondary hover:text-white transition-colors">
          Request Free Estimate
        </a>
        <a href="/gallery" class="inline-flex items-center justify-center px-0 py-5 text-xs font-bold uppercase tracking-[0.2em] text-white border-b border-white hover:text-secondary hover:border-secondary transition-colors">
          View Our Work
        </a>
      </div>
    </div>

  </div>
</BackgroundGrid>

<script>
  import { animate, stagger, scroll } from "motion";

  // Initial load animations
  const lines = document.querySelectorAll(".hero-title-line");
  const reveals = document.querySelectorAll(".hero-reveal");
  const imgContainer = document.getElementById("hero-img-container");
  
  if (lines.length > 0) {
    animate(
      lines,
      { y: ["100%", "0%"] },
      { duration: 1, easing: [0.22, 1, 0.36, 1], delay: stagger(0.15, { start: 0.1 }) }
    );
  }

  if (reveals.length > 0) {
    animate(
      reveals,
      { opacity: [0, 1], y: [20, 0] },
      { duration: 0.8, easing: "ease-out", delay: stagger(0.1, { start: 0.6 }) }
    );
  }

  // Scroll parallax for image
  /*
  const heroImg = document.getElementById("hero-img");
  const section = document.querySelector("section");
  if (heroImg && section) {
    scroll(
      animate(heroImg, { y: ["0%", "-15%"] }),
      { target: section, offset: ["start start", "end start"] }
    );
  }
  */
</script>