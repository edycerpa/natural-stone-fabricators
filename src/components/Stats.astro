---
const stats = [
  { value: "20+", label: "Years in Orange County" },
  { value: "3500+", label: "Countertops installed" },
  { value: "100%", label: "Local fabrication" },
  { value: "5★", label: "Repeat client base" },
];
---

<section class="relative overflow-hidden bg-ink py-20 sm:py-28">
  <!-- Dynamic glow effect -->
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="absolute -top-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-primary/20 blur-[120px]"></div>
    <div class="absolute -bottom-[20%] -right-[10%] w-[50%] h-[50%] rounded-full bg-secondary/20 blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 text-center relative">
      {stats.map(({ value, label }, i) => (
        <div
          class={`relative flex flex-col items-center justify-center p-8 rounded-2xl glass-dark ${i > 0 ? "lg:before:absolute lg:before:left-0 lg:before:top-1/2 lg:before:-translate-y-1/2 lg:before:h-16 lg:before:w-px lg:before:bg-gradient-to-b lg:before:from-transparent lg:before:via-shade-light/20 lg:before:to-transparent" : ""}`}
          data-anim="fade-up"
          data-anim-delay={(i + 1) * 150}
        >
          <p class="text-white text-5xl sm:text-6xl font-serif tracking-tight">{value}</p>
          <p class="eyebrow mt-4 text-primary-light">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>