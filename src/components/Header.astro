---
import logo from "../assets/logo.png";
const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || (href !== "/" && pathname.startsWith(href));

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
];
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 bg-ink transition-transform duration-500 border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24">
      <a href="/" class="flex items-center shrink-0">
        <img
          src={logo.src}
          alt="Natural Stone Fabricators"
          width="250"
          height="84"
          loading="eager"
        />
      </a>

      <nav class="hidden md:flex items-center gap-12 ml-auto">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "text-xs font-bold tracking-[0.2em] uppercase transition-colors relative overflow-hidden group py-2",
              isActive(href) ? "text-white" : "text-shade-light hover:text-white",
            ]}
          >
            <span class="block relative z-10">{label}</span>
            <!-- Elegant animated underline -->
            <span class="absolute bottom-0 left-0 w-full h-[1px] bg-white transform origin-left transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] scale-x-0 group-hover:scale-x-100"></span>
          </a>
        ))}
        <a
          href="/contact"
          class="ml-4 inline-flex items-center px-8 py-4 text-xs font-bold uppercase tracking-[0.2em] bg-accent text-ink border border-accent hover:bg-transparent hover:text-accent transition-colors"
        >
          Free Estimate
        </a>
      </nav>

      <div class="flex items-center gap-3">
        <button
          id="nav-toggle"
          type="button"
          aria-label="Open menu"
          class="md:hidden inline-flex items-center justify-center w-10 h-10 text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu: Brutalist / Editorial full width -->
    <nav id="mobile-menu" class="md:hidden hidden flex-col bg-ink border-t border-white/10 absolute top-full inset-x-0 h-[calc(100vh-6rem)]">
      <div class="flex flex-col px-4 pt-8 gap-6">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "text-2xl font-serif tracking-tight border-b border-white/10 pb-4",
              isActive(href) ? "text-secondary" : "text-white",
            ]}
          >
            {label}
          </a>
        ))}
        <a
          href="/contact"
          class="block py-5 mt-4 text-center text-xs font-bold uppercase tracking-[0.2em] bg-accent text-ink border border-accent hover:bg-transparent hover:text-accent transition-colors"
        >
          Free Estimate
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  import { animate } from "motion";

  const navBtn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  if (navBtn && menu) {
    navBtn.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      if (isHidden) {
        menu.classList.remove('hidden');
        menu.classList.add('flex');
        document.body.style.overflow = 'hidden';
        
        // Motion API for mobile menu entrance
        animate(menu, { opacity: [0, 1], y: [-20, 0] }, { duration: 0.4, easing: "ease-out" });
      } else {
        animate(menu, { opacity: 0, y: -20 }, { duration: 0.3, easing: "ease-in" }).then(() => {
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          document.body.style.overflow = '';
        });
      }
    });
  }

  // Hide header on scroll down, show on scroll up (Editorial standard)
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 100 && currentScroll > lastScroll) {
      header?.classList.add('-translate-y-full');
    } else {
      header?.classList.remove('-translate-y-full');
    }
    lastScroll = currentScroll;
  }, { passive: true });
</script>