---
import { Image } from "astro:assets";
import imgKitchen from "../assets/image-12.jpg";
import imgBath from "../assets/image-13.jpg";
import imgOutdoor from "../assets/image-01.jpg";
import imgCommercial from "../assets/image-10.jpg";

const services = [
  { id: "kitchen", title: "Kitchen Countertops", img: imgKitchen },
  { id: "bath", title: "Bathroom Vanities", img: imgBath },
  { id: "outdoor", title: "Outdoor Living", img: imgOutdoor },
  { id: "commercial", title: "Commercial Projects", img: imgCommercial }
];
---

<section class="py-24 lg:py-40 bg-ink text-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20 service-header-anim">
      <div class="max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-secondary mb-6">Capabilities</p>
        <h2 class="text-4xl sm:text-5xl lg:text-7xl font-serif leading-[0.9] tracking-tight">
          Crafted for <br/> <span class="italic text-primary-ultra-light">every room.</span>
        </h2>
      </div>
      <p class="text-sm text-shade-light max-w-sm font-sans leading-relaxed">
        From the kitchen island that anchors your morning routine to the fireplace surround that frames family time.
      </p>
    </div>

    <!-- Editorial Interactive List -->
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative">
      
      <!-- List -->
      <div class="w-full lg:w-1/2 flex flex-col z-10" id="services-list">
        {services.map((service, index) => (
          <div 
            class="service-item group py-8 border-b border-white/10 cursor-pointer flex items-center justify-between"
            data-index={index}
          >
            <h3 class="text-3xl sm:text-4xl lg:text-5xl font-serif text-white/50 group-hover:text-white transition-colors duration-500">
              {service.title}
            </h3>
            <span class="text-sm font-sans text-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-500 transform translate-x-4 group-hover:translate-x-0">Explore</span>
          </div>
        ))}
      </div>

      <!-- Image Display (Sticky on desktop) -->
      <div class="w-full lg:w-1/2 h-[50vh] lg:h-[70vh] relative overflow-hidden" id="services-gallery">
        {services.map((service, index) => (
          <div class={`absolute inset-0 transition-opacity duration-700 ease-in-out service-image ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`} data-image-index={index}>
            <Image 
              src={service.img} 
              alt={service.title} 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-ink/20"></div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>

<script>
  import { animate, inView, stagger } from "motion";

  // Intersection animations
  inView(".service-header-anim", (info) => {
    animate(info.target, { opacity: [0, 1], y: [40, 0] }, { duration: 0.8, easing: "ease-out" });
  });

  inView("#services-list", (info) => {
    const items = info.target.querySelectorAll('.service-item');
    animate(
      items, 
      { opacity: [0, 1], x: [-30, 0] }, 
      { duration: 0.8, delay: stagger(0.15), easing: "ease-out" }
    );
  });

  // Hover interaction
  const serviceItems = document.querySelectorAll('.service-item');
  const serviceImages = document.querySelectorAll('.service-image');

  serviceItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      const index = item.getAttribute('data-index');
      
      serviceImages.forEach(img => {
        if (img.getAttribute('data-image-index') === index) {
          img.classList.remove('opacity-0', 'z-0');
          img.classList.add('opacity-100', 'z-10');
        } else {
          img.classList.remove('opacity-100', 'z-10');
          img.classList.add('opacity-0', 'z-0');
        }
      });
    });
  });
</script>