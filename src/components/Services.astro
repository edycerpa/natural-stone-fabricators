---
import { Image } from "astro:assets";
import imgKitchen from "../assets/image-12.jpg";
import imgBath from "../assets/image-01.jpg";
import imgOutdoor from "../assets/mesa-fuego-granito-exterior.jpg";
import imgCommercial from "../assets/image-10.jpg";

const services = [
  { id: "kitchen", title: "Kitchen Countertops", img: imgKitchen },
  { id: "bath", title: "Bathroom Vanities", img: imgBath },
  { id: "outdoor", title: "Outdoor Living", img: imgOutdoor },
  { id: "commercial", title: "Commercial Projects", img: imgCommercial }
];
---

<section class="py-24 lg:py-40 bg-background text-ink relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Editorial Layout: Left Text/List, Right Image -->
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative">
      
      <!-- Left Column: Header + List -->
      <div class="w-full lg:w-2/5 flex flex-col z-10">
        
        <div class="mb-10 service-header-anim">
          <div class="max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-secondary mb-6">Capabilities</p>
            <h2 class="text-6xl sm:text-7xl lg:text-9xl font-serif text-ink leading-[0.9] tracking-tight mb-6">
              Crafted for <br/> <span class="italic text-secondary">every room.</span>
            </h2>
            <p class="text-base text-shade-dark max-w-md font-sans leading-relaxed">
              From the kitchen island that anchors your morning routine to the fireplace surround that frames family time.
            </p>
          </div>
        </div>

        <div id="services-list">
          {services.map((service, index) => (
            <div 
              class="service-item group py-6 border-b border-ink/10 hover:border-ink cursor-pointer flex items-center justify-between transition-colors duration-500"
              data-index={index}
            >
              <h3 class="text-4xl sm:text-5xl lg:text-6xl font-serif text-shade-dark group-hover:text-secondary transition-colors duration-500">
                {service.title}
              </h3>
            </div>
          ))}
        </div>
      </div>

      <!-- Image Display (Matches left column height on desktop) -->
      <div class="w-full lg:w-3/5 h-[50vh] lg:h-auto relative overflow-hidden" id="services-gallery">
        {services.map((service, index) => (
          <div class={`absolute inset-0 transition-opacity duration-700 ease-in-out service-image ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`} data-image-index={index}>
            <Image 
              src={service.img} 
              alt={service.title} 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-ink/20"></div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>

<script>
  import { animate, inView, stagger } from "motion";

  // Intersection animations
  inView(".service-header-anim", (info) => {
    animate(info.target, { opacity: [0, 1], y: [40, 0] }, { duration: 0.8, easing: "ease-out" });
  });

  inView("#services-list", (info) => {
    const items = info.target.querySelectorAll('.service-item');
    animate(
      items, 
      { opacity: [0, 1], x: [-30, 0] }, 
      { duration: 0.8, delay: stagger(0.15), easing: "ease-out" }
    );
  });

  // Hover interaction
  const serviceItems = document.querySelectorAll('.service-item');
  const serviceImages = document.querySelectorAll('.service-image');

  serviceItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      const index = item.getAttribute('data-index');
      
      serviceImages.forEach(img => {
        if (img.getAttribute('data-image-index') === index) {
          img.classList.remove('opacity-0', 'z-0');
          img.classList.add('opacity-100', 'z-10');
        } else {
          img.classList.remove('opacity-100', 'z-10');
          img.classList.add('opacity-0', 'z-0');
        }
      });
    });
  });
</script>